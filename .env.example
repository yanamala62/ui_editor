# ================================
# AI CONFIGURATION
# ================================
AI_PROVIDER=kiro
AI_API_KEY=your_kiro_api_key_here
AI_BASE_URL=https://accounts.atxp.ai
AI_MODEL=gpt-4o
AI_CONNECTION_TOKEN=your_connection_token
AI_ACCOUNT_ID=your_account_id
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT=30000
AI_RATE_LIMIT=60

# ================================
# SERVER CONFIGURATION
# ================================
SERVER_PORT=3001
WS_PORT=3002
NODE_ENV=development

# ================================
# SECURITY
# ================================
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# ================================
# DEFAULTS
# ================================
DEFAULT_REPO_PATH=
DEFAULT_LOCALHOST_URL=http://localhost:3000
DEFAULT_FRAMEWORK=react
MAX_BACKUPS=10
LOG_LEVEL=info
